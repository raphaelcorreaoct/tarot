# OpenAI API Key - obtenha em https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Stripe - obtenha em https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...

# IDs dos preços (crie os produtos no Stripe Dashboard e copie os price_xxx)
# Produto 1: R$ 9,90 - Leitura única (3 cartas)
STRIPE_PRICE_SINGLE=price_...
# Produto 2: R$ 24,90 - Pacote 3 leituras
STRIPE_PRICE_PACKAGE=price_...

# Opcional: URL base do app (para redirects do Stripe)
# NEXT_PUBLIC_APP_URL=https://seusite.com

# Sessão - gere uma string aleatória de 32+ caracteres para produção
SESSION_SECRET=change-me-in-production-min-32-chars!!

# MailerSend - envio de leituras por e-mail
# API Key: https://app.mailersend.com/api-tokens
# O e-mail remetente deve estar em um domínio verificado no MailerSend
MAILERSEND_API_KEY=mlsn....
MAILERSEND_FROM_EMAIL=noreply@seudominio.com
MAILERSEND_FROM_NAME=Tarot
